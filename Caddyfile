{
    debug
    	log default {
            output stdout
            format json
            level {$CADDY_LOG_LEVEL}
        }
}

(openbis) {
    log default

    # Proxy for all openBIS instances.
    # The openbis-instance cookie (set at login) carries the target hostname.
    # Adding a new instance only requires a new entry in src/config/instances.ts.

    @openbis {
        path /openbis/*
        header_regexp instance Cookie "openbis-instance=([^;]+)"
    }
    handle @openbis {
        reverse_proxy {re.instance.1}:443 {
            transport http {
                tls
                tls_insecure_skip_verify
            }
            header_up Host {re.instance.1}
        }
    }

    @datastore_server {
        path /datastore_server/*
        header_regexp instance Cookie "openbis-instance=([^;]+)"
    }
    handle @datastore_server {
        reverse_proxy {re.instance.1}:443 {
            transport http {
                tls
                tls_insecure_skip_verify
            }
            header_up Host {re.instance.1}
        }
    }

    handle {
        header {
            # Prevent XSS: the main attack vector for localStorage token theft.
            # - script-src 'self': no inline scripts, no eval, no external scripts
            # - style-src 'unsafe-inline': needed for HeroUI/Tailwind runtime styles
            # - connect-src 'self': XHR/fetch only to same origin (proxy handles routing)
            # - frame-ancestors 'none': prevents the app from being embedded in an iframe on another site
            Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src 'self'; font-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'"
        }
        root * /var/www/html
        try_files {path} /index.html
        file_server
    }
}

:80 {
    import openbis
}
